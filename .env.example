# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Nebro
APP_ENV=local
APP_KEY=                          # php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database — tenant template (stancl switches this per-request at runtime) ─
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nebro_default
DB_USERNAME=root
DB_PASSWORD=

# ─── Database — central (global users, tenants, social_identities, telescope) ─
DB_CENTRAL_HOST=127.0.0.1
DB_CENTRAL_PORT=3306
DB_CENTRAL_DATABASE=nebro_central
DB_CENTRAL_USERNAME=root
DB_CENTRAL_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────────
# phpredis C extension (installed via pecl install redis for PHP 8.4). Fall back to predis if unavailable.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0          # default / general
REDIS_CACHE_DB=1    # cache store (tenant-prefixed by CacheTenancyBootstrapper)
REDIS_SESSION_DB=2  # sessions — NOT tenant-prefixed (scoped by session cookie)
REDIS_QUEUE_DB=3    # queue — NOT tenant-prefixed (tenant ID in job payload)

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=queue

# ─── Auth / Sanctum ───────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─── Google SSO ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_PEOPLE_FIELDS=photos

# ─── Meilisearch ──────────────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=
MEILISEARCH_TIMEOUT=3

# ─── Payment ──────────────────────────────────────────────────────────────────
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Telescope (local dev only) ───────────────────────────────────────────────
TELESCOPE_ENABLED=true
TELESCOPE_DB_CONNECTION=central

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@nebro.test"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

